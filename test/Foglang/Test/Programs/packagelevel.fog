package main

import "fmt"

let mult (a : float64) -> (b : float64) => float64 = a * b

fmt.Println (mult 2.0 3.0)
fmt.Println (mult 0.5 6.0)

let base : int = 10

let offset : int =
  fmt.Println "Computing offset"
  25

let main () => unit =
  fmt.Println base
  fmt.Println offset
  fmt.Println (base + offset)

fmt.Println (mult 1.5 9.0)
