package main

import "fmt"

// If/else as expression (returned from function)
let abs (x : int) => int =
  if x < 0 then 0 - x else x

// If/else as statement (unit-returning body)
let printSign (x : int) => () =
  if x < 0 then fmt.Println "negative"
  else if x == 0 then fmt.Println "zero"
  else fmt.Println "positive"

// Nested let-in returning a value
let letExpr (x : int) => int =
  let a : int = x + 1
  let b : int = a * 2
  a + b

// Let binding a unit-typed expression, then returning a value
let letUnitThenValue (x : int) => int =
  let _ : () = fmt.Println "side effect"
  x * 10

// If/else expression nested inside a larger expression
let condAdd (x : int) (y : int) => int =
  x + (if y > 0 then y else 0 - y)

// Binary ops in statement context (result discarded)
let opsAsStmts () => () =
  1 + 2
  3 * 4
  fmt.Println "done"

// Side-effect statements followed by a returned expression
let stmtsThenExpr (x : int) => int =
  fmt.Println "first"
  fmt.Println "second"
  fmt.Println "third"
  x

// Local function def followed by use
let localFuncUse () => () =
  let double (n : int) => int = n * 2
  fmt.Println (double 21)

// Lambda as argument (expression position)
let applyToTen (f : (int => int)) => int = f 10

let lambdaArg () => () =
  fmt.Println (applyToTen (func (x : int) => int = x + 5))

// Nested if/else as expression
let clamp (lo : int) (hi : int) (x : int) => int =
  if x < lo then lo
  else if x > hi then hi
  else x

// Package-level expression statement (becomes init())
fmt.Println "init side effect"

// Package-level var with literal
let simpleVar : int = 7

// Package-level var with binary op expression
let exprVar : int = 3 + 4

// Package-level var with if/else expression
let condVar : int = if true then 1 else 0

// Package-level var with let-in expression
let letVar : int =
  let x : int = 10
  x + 5

// Package-level var with sequence body (side effects then value)
let computed : int =
  fmt.Println "computing global"
  42

// If/else expression in let binding
let ifInLet (x : int) => int =
  let sign : int = if x < 0 then 0 - 1 else 1
  x * sign

// Lambda in let binding
let lambdaInLet () => () =
  let f : (int => int) = func (x : int) => int = x * x
  fmt.Println (f 7)

// Literal as sole function body
let constVal () => int = 42

// Side-effect statements then if/else as returned expression
let stmtsThenIf (x : int) => int =
  fmt.Println "checking"
  if x > 0 then x else 0 - x

let main () => () =
  fmt.Println (abs 5)
  fmt.Println (abs (0 - 3))
  printSign 5
  printSign 0
  printSign (0 - 1)
  fmt.Println (letExpr 3)
  fmt.Println (letUnitThenValue 4)
  fmt.Println (condAdd 10 5)
  fmt.Println (condAdd 10 (0 - 5))
  opsAsStmts ()
  fmt.Println (stmtsThenExpr 99)
  localFuncUse ()
  lambdaArg ()
  fmt.Println (clamp 0 100 50)
  fmt.Println (clamp 0 100 (0 - 5))
  fmt.Println (clamp 0 100 200)
  fmt.Println simpleVar
  fmt.Println exprVar
  fmt.Println condVar
  fmt.Println letVar
  fmt.Println computed
  fmt.Println (ifInLet 5)
  fmt.Println (ifInLet (0 - 3))
  lambdaInLet ()
  fmt.Println (constVal ())
  fmt.Println (stmtsThenIf 5)
  fmt.Println (stmtsThenIf (0 - 3))
